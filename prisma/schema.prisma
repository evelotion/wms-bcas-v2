generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Prisma akan otomatis pakai ini saat db push
}

// --- MASTER DATA ---
model Master_Barang {
  id                   String   @id @default(uuid())
  sku                  String   @unique
  nama                 String
  kategori             String
  satuan               String // Pcs, Buku, Rim, dll
  satuan_besar         String?
  isi_per_satuan_besar Int      @default(1)
  minimum_order_besar  Int?
  batas_minimum        Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  batches           Batch_Barang[]
  permintaanDetails Permintaan_Detail[]
  outstandings      Permintaan_Outstanding[] // Relasi untuk histori barang ngutang
}

model Lokasi_Rak {
  id      String @id @default(uuid())
  gudang  String
  lorong  String
  rak     String
  qr_code String @unique

  batches Batch_Barang[]
}

model Batch_Barang {
  id            String   @id @default(cuid())
  barangId      String
  lokasiId      String
  tanggal_masuk DateTime @default(now())
  qty_awal      Int
  qty_sisa      Int
  harga_satuan  Float

  // Data spesifik per batch penerimaan
  supplier        String?
  nomorator_awal  String?
  nomorator_akhir String?

  status    StatusBatch @default(AVAILABLE)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  barang    Master_Barang   @relation(fields: [barangId], references: [id])
  lokasi    Lokasi_Rak      @relation(fields: [lokasiId], references: [id])
  mutasi    Mutasi_Ledger[]
  item_seri Item_Seri[]
}

model Item_Seri {
  id         String       @id @default(uuid())
  batchId    String
  batch      Batch_Barang @relation(fields: [batchId], references: [id])
  nomor_seri String
  is_used    Boolean      @default(false)
}

model Mutasi_Ledger {
  id      String       @id @default(uuid())
  batchId String
  batch   Batch_Barang @relation(fields: [batchId], references: [id])

  tipe_mutasi   TipeMutasi
  qty_perubahan Int // Positif untuk INBOUND/RETUR, negatif untuk OUTBOUND
  saldo_akhir   Int // Snapshot sisa qty di batch ini SETELAH mutasi terjadi
  referensi     String? // Nomor PO, Bukti FPKB, atau ID Requisition
  keterangan    String?
  createdAt     DateTime   @default(now())
  createdBy     String // ID User/Petugas
}

enum StatusBatch {
  QUARANTINE
  AVAILABLE
  DEPLETED
}

enum TipeMutasi {
  INBOUND
  OUTBOUND
  RETUR
}

// === ENUM BARU UNTUK FLOW ADMIN & GUDANG ===
enum Role {
  ADMIN
  GUDANG
}

enum StatusPermintaan {
  PENDING_GUDANG // FPKB digenerate Admin, nunggu di-adjust Staf Gudang
  PARTIAL // Diproses Gudang tapi ada barang Outstanding
  COMPLETED // Selesai 100% dipenuhi
}

enum StatusItem {
  FULFILLED // Dipenuhi 100%
  PARTIAL // Dipenuhi sebagian, sisanya masuk outstanding
  OUTSTANDING // 0% dipenuhi (stok kosong)
  CANCELLED // Dibatalkan permanen
}

// --- MODUL PERMINTAAN (REQUISITION) ---
model Permintaan_Header {
  id         String  @id @default(cuid())
  nomor_fpp  String  @unique // Form FPP dari Cabang
  nomor_fpkb String? @unique // Generate Otomatis oleh Staf Admin
  cabang     String // Tujuan / Unit kerja
  pic_nama   String // Nama yang minta

  status     StatusPermintaan @default(PENDING_GUDANG) // Status awal saat di-generate
  keterangan String?

  // Tracking siapa yang bikin dan siapa yang eksekusi
  adminId  String? // User ID Staf Admin yang input
  gudangId String? // User ID Staf Gudang yang proses

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  details      Permintaan_Detail[]
  outstandings Permintaan_Outstanding[]

  admin  User? @relation("AdminPembuat", fields: [adminId], references: [id])
  gudang User? @relation("GudangPemroses", fields: [gudangId], references: [id])
}

model Permintaan_Detail {
  id            String     @id @default(cuid())
  headerId      String
  barangId      String
  qty_diminta   Int // Jumlah yang di-input Admin dari FPP
  qty_disetujui Int        @default(0) // Jumlah yang dieksekusi/di-adjust Gudang
  status_item   StatusItem @default(OUTSTANDING)
  keterangan    String?

  header Permintaan_Header @relation(fields: [headerId], references: [id], onDelete: Cascade)
  barang Master_Barang     @relation(fields: [barangId], references: [id])
}

// --- TABEL OUTSTANDING ---
model Permintaan_Outstanding {
  id       String            @id @default(uuid())
  headerId String // Nyambung ke FPKB awal biar gampang dilacak
  header   Permintaan_Header @relation(fields: [headerId], references: [id], onDelete: Cascade)

  barangId String
  barang   Master_Barang @relation(fields: [barangId], references: [id])

  qty_sisa Int // Selisih (qty_diminta - qty_disetujui)
  status   StatusItem @default(OUTSTANDING) // Kalau disusulin nanti, jadi FULFILLED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- MODUL SECURITY & AUTH ---
model User {
  id       String @id @default(cuid())
  username String @unique
  nama     String
  password String // Pastikan di-bcrypt pas production
  role     Role   @default(ADMIN) // Pakai Enum Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relasi balik untuk tracking kerjaan
  fpkb_dibuat   Permintaan_Header[] @relation("AdminPembuat")
  fpkb_diproses Permintaan_Header[] @relation("GudangPemroses")
}
