generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MASTER DATA ---
model Master_Barang {
  id            String   @id @default(uuid())
  sku           String   @unique
  nama          String
  kategori      String
  satuan        String // Pcs, Buku, Rim, dll
  batas_minimum Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batches           Batch_Barang[]
  permintaanDetails Permintaan_Detail[]
  outstandings      Permintaan_Outstanding[] // TAMBAHAN: Relasi untuk histori barang ngutang
}

model Lokasi_Rak {
  id      String @id @default(uuid())
  gudang  String
  lorong  String
  rak     String
  qr_code String @unique

  batches Batch_Barang[]
}

model Batch_Barang {
  id            String   @id @default(cuid())
  barangId      String
  lokasiId      String
  tanggal_masuk DateTime @default(now())
  qty_awal      Int
  qty_sisa      Int
  harga_satuan  Float

  // Data spesifik per batch penerimaan
  supplier  String?
  nomorator String?
  
  status    StatusBatch @default(AVAILABLE) // AVAILABLE, QUARANTINE, DEPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  barang Master_Barang   @relation(fields: [barangId], references: [id])
  lokasi Lokasi_Rak      @relation(fields: [lokasiId], references: [id])
  mutasi Mutasi_Ledger[]

  item_seri Item_Seri[]
}

model Item_Seri {
  id         String       @id @default(uuid())
  batchId    String
  batch      Batch_Barang @relation(fields: [batchId], references: [id])
  nomor_seri String // Bisa spesifik atau range (e.g., "0001-1000")
  is_used    Boolean      @default(false)
}

model Mutasi_Ledger {
  id      String       @id @default(uuid())
  batchId String
  batch   Batch_Barang @relation(fields: [batchId], references: [id])

  tipe_mutasi   TipeMutasi
  qty_perubahan Int // Positif untuk INBOUND/RETUR, negatif untuk OUTBOUND
  saldo_akhir   Int // Snapshot sisa qty di batch ini SETELAH mutasi terjadi
  referensi     String? // Nomor PO, Bukti FPKB, atau ID Requisition
  keterangan    String?

  createdAt DateTime @default(now())
  createdBy String // ID User/Petugas
}

enum StatusBatch {
  QUARANTINE
  AVAILABLE
  DEPLETED
}

enum TipeMutasi {
  INBOUND
  OUTBOUND
  RETUR
}

// === ENUM BARU UNTUK FLOW FPKB & OUTSTANDING ===
enum StatusPermintaan {
  DRAFT         // Form FPP di-upload, belum di-generate FPKB
  RESERVED      // FPKB di-generate SPV, nunggu diambil petugas gudang
  PICKED        // Sedang disiapkan petugas gudang
  COMPLETED     // Selesai diserahterimakan
}

enum StatusItem {
  FULFILLED     // Dipenuhi 100%
  PARTIAL       // Dipenuhi sebagian, sisanya masuk outstanding
  OUTSTANDING   // 0% dipenuhi (stok kosong)
  CANCELLED     // Dibatalkan permanen
}

// --- MODUL FASE 2: PERMINTAAN CABANG (REQUISITION) ---

model Permintaan_Header {
  id            String  @id @default(cuid())
  nomor_fpp     String  @unique // Diubah dari nomor_request. Contoh input cabang: 070/FPP/LOG/2026
  nomor_fpkb    String? @unique // Generate Otomatis. Contoh: 00001/FPKB-CTK/LOG/2026
  cabang        String // Tujuan / Unit kerja
  pic_nama      String // Nama yang minta
  status        StatusPermintaan @default(DRAFT) // Pakai Enum baru
  keterangan    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  details      Permintaan_Detail[]
  outstandings Permintaan_Outstanding[] // Relasi ke barang yang kurang (Outstanding)
}

model Permintaan_Detail {
  id            String  @id @default(cuid())
  headerId      String
  barangId      String
  qty_diminta   Int // Jumlah yang direquest cabang
  qty_disetujui Int      @default(0) // Jumlah yang disetujui SPV
  status_item   StatusItem @default(OUTSTANDING) // Pakai Enum baru
  keterangan    String?

  header Permintaan_Header @relation(fields: [headerId], references: [id], onDelete: Cascade)
  barang Master_Barang     @relation(fields: [barangId], references: [id])
}

// --- TABEL BARU: OUTSTANDING ---
model Permintaan_Outstanding {
  id             String   @id @default(uuid())
  headerId       String   // Nyambung ke Form FPP awal biar gampang dilacak utangnya
  header         Permintaan_Header @relation(fields: [headerId], references: [id], onDelete: Cascade)
  
  barangId       String
  barang         Master_Barang @relation(fields: [barangId], references: [id])
  
  qty_sisa       Int      // Sisa barang yang belum dikirim ke cabang
  status         StatusItem @default(OUTSTANDING) // Kalau disusulin nanti, jadi FULFILLED
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- MODUL FASE 5: SECURITY & AUTH ---
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  nama      String
  password  String   // Untuk MVP kita simpan plain text, di production wajib bcrypt!
  role      String   @default("STAF") // Pilihan: "SPV" atau "STAF"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}